# Required: GitHub personal access token (needs repo scope)
GITHUB_TOKEN=ghp_your_token_here

# Required: Your GitHub username (personal repos are always scanned)
GITHUB_USERNAME=your_username

# Optional: Path to local projects directory for filesystem enrichment
# Scanner checks 2 levels deep for git repos
LOCAL_PROJECTS_DIR=/Users/you/claude

# Optional: Comma-separated GitHub orgs to scan (in addition to personal repos)
GITHUB_ORGS=my-org,another-org

# Optional: Anthropic API key for Claude-powered "What's Next" suggestions
ANTHROPIC_API_KEY=sk-ant-your_key_here
